---
import { buildSeo } from '../utils/seo.mjs';
import { siteMeta } from '../utils/site-meta.mjs';

const route = Astro.locals.starlightRoute;
const seo = buildSeo(route, Astro.url);
const imageType = seo.imageType;

const filteredHead = route.head.filter((entry) => {
	if (entry.tag !== 'meta' || !entry.attrs) return true;
	return (
		entry.attrs.property !== 'og:type' &&
		entry.attrs.property !== 'og:locale' &&
		entry.attrs.name !== 'ad-profile' &&
		entry.attrs.name !== 'commercial-intent'
	);
});

---

{filteredHead.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
<link rel="manifest" href="/site.webmanifest" />
<link rel="alternate" type="application/rss+xml" title={`${seo.siteName} RSS Feed`} href="/rss.xml" />
<link rel="apple-touch-icon" href={siteMeta.appleTouchIconPath} />
<link rel="icon" type="image/svg+xml" href={siteMeta.faviconPath} />
<meta name="theme-color" content={seo.themeColor} />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="robots" content={seo.robots} />
<meta name="googlebot" content={seo.robots} />
<meta name="application-name" content={seo.siteName} />
<meta name="apple-mobile-web-app-title" content={seo.siteName} />
<meta name="author" content={seo.authorName} />
<meta name="creator" content={seo.authorName} />
{seo.editorName && <meta name="editor" content={seo.editorName} />}
{seo.authorUrl && <link rel="author" href={seo.authorUrl} />}
<meta property="og:type" content={seo.ogType} />
<meta property="og:site_name" content={seo.siteName} />
<meta property="og:locale" content={seo.ogLocale} />
<meta property="og:url" content={seo.canonicalUrl} />
<meta property="og:image" content={seo.imageUrl} />
<meta property="og:image:secure_url" content={seo.imageUrl} />
<meta property="og:image:type" content={imageType} />
<meta property="og:image:width" content={String(seo.imageWidth)} />
<meta property="og:image:height" content={String(seo.imageHeight)} />
<meta property="og:image:alt" content={seo.imageAlt} />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={seo.imageUrl} />
<meta name="twitter:image:alt" content={seo.imageAlt} />
{seo.twitterSite && <meta name="twitter:site" content={seo.twitterSite} />}
{seo.modifiedTime && <meta property="og:updated_time" content={seo.modifiedTime} />}
{seo.publishedTime && seo.ogType === 'article' && (
	<meta property="article:published_time" content={seo.publishedTime} />
)}
{seo.articleSection && <meta property="article:section" content={seo.articleSection} />}
{seo.articleTags.map((tag) => (
	<meta property="article:tag" content={tag} />
))}
{seo.modifiedTime && seo.ogType === 'article' && (
	<meta property="article:modified_time" content={seo.modifiedTime} />
)}
{import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
	<meta
		name="google-site-verification"
		content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION}
	/>
)}
{import.meta.env.PUBLIC_BING_SITE_VERIFICATION && (
	<meta name="msvalidate.01" content={import.meta.env.PUBLIC_BING_SITE_VERIFICATION} />
)}
{import.meta.env.PUBLIC_YANDEX_SITE_VERIFICATION && (
	<meta
		name="yandex-verification"
		content={import.meta.env.PUBLIC_YANDEX_SITE_VERIFICATION}
	/>
)}
<script
	is:inline
	async
	src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6017297149672924"
	crossorigin="anonymous"
></script>
<script type="application/ld+json" is:inline set:html={JSON.stringify(seo.structuredData)} />
