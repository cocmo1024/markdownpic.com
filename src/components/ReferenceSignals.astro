---
type RouteData = Record<string, unknown>;
type Signal = {
	label: string;
	value: string | string[];
	list?: boolean;
};

const route = Astro.locals.starlightRoute;
const data = (route.entry?.data ?? {}) as RouteData;

const intentLabels: Record<string, string> = {
	learn: 'Learn',
	compare: 'Compare',
	select: 'Select',
	design: 'Design',
	deploy: 'Deploy',
};

const stageLabels: Record<string, string> = {
	'problem-aware': 'Problem Aware',
	'solution-aware': 'Solution Aware',
	'vendor-aware': 'Vendor Aware',
	shortlist: 'Shortlist',
	implementation: 'Implementation',
	operations: 'Operations',
};

const statusLabels: Record<string, string> = {
	seed: 'Seed',
	growing: 'Growing',
	cornerstone: 'Cornerstone',
};

const roles =
	Array.isArray(data.targetRoles) && data.targetRoles.every((role) => typeof role === 'string')
		? data.targetRoles
		: [];
const keyQuestions =
	Array.isArray(data.keyQuestions) && data.keyQuestions.every((item) => typeof item === 'string')
		? data.keyQuestions
		: [];
const notFor =
	Array.isArray(data.notFor) && data.notFor.every((item) => typeof item === 'string')
		? data.notFor
		: [];
const updateTriggers =
	Array.isArray(data.updateTriggers) && data.updateTriggers.every((item) => typeof item === 'string')
		? data.updateTriggers
		: [];

const signals = [
	typeof data.problemSolved === 'string' && { label: 'Problem Solved', value: data.problemSolved },
	typeof data.readerTakeaway === 'string' && { label: 'Reader Outcome', value: data.readerTakeaway },
	typeof data.primaryKeyword === 'string' && { label: 'Primary Keyword', value: data.primaryKeyword },
	typeof data.searchIntent === 'string' && {
		label: 'Search Intent',
		value: intentLabels[data.searchIntent] ?? data.searchIntent,
	},
	typeof data.decisionStage === 'string' && {
		label: 'Decision Stage',
		value: stageLabels[data.decisionStage] ?? data.decisionStage,
	},
	roles.length > 0 && { label: 'Target Roles', value: roles, list: true },
	keyQuestions.length > 0 && { label: 'Key Questions', value: keyQuestions, list: true },
	notFor.length > 0 && { label: 'Poor Fit', value: notFor, list: true },
	typeof data.contentStatus === 'string' && {
		label: 'Content Status',
		value: statusLabels[data.contentStatus] ?? data.contentStatus,
	},
	typeof data.reviewCadence === 'string' && { label: 'Review Cadence', value: data.reviewCadence },
	updateTriggers.length > 0 && { label: 'Update Triggers', value: updateTriggers, list: true },
].filter(Boolean) as Signal[];
---

{
	signals.length > 0 && (
		<section class="reference-signals">
			<h2>Reference Signals</h2>
			<dl>
				{signals.map(({ label, value, list }) => (
					<div>
						<dt>{label}</dt>
						<dd>
							{
								list && Array.isArray(value) ? (
									<ul class="reference-signals__list">
										{value.map((item) => (
											<li>{item}</li>
										))}
									</ul>
								) : (
									<p class="reference-signals__text">
										{Array.isArray(value) ? value.join(', ') : value}
									</p>
								)
							}
						</dd>
					</div>
				))}
			</dl>
		</section>
	)
}
